  "tool_contracts": {
    "check_slots": {
      "input_fields": [
        "course_query",
        "term"
      ],
      "lookup_keys": [
        "course_code",
        "aliases",
        "title"
      ],
      "returns": [
        "course_code",
        "title",
        "sections",
        "availability_status",
        "warnings"
      ]
    },
    "get_tuition": {
      "input_fields": [
        "course_code",
        "student_id"
      ],
      "returns": [
        "base_tuition",
        "fees",
        "estimated_total"
      ]
    },
    "register": {
      "input_fields": [
        "student_id",
        "section_ids",
        "confirm_payment"
      ],
      "returns": [
        "registration_status",
        "registered_sections",
        "waitlisted_sections",
        "errors"
      ]
    }
  },
